page {
  /* ===== 设计令牌 Design Tokens ===== */
  --bg: #f4f6f8;
  --card: #ffffff;
  --primary: #07c160;
  --primary-deep: #06a856;
  --primary-soft: #e9f9f0;
  --primary-tint: #f1fcf6;
  --text-1: #1b1f24;
  --text-2: #5b6470;
  --text-3: #9aa3ad;
  --line: rgba(20, 28, 40, 0.06);
  --shadow-card: 0 8rpx 28rpx rgba(20, 28, 40, 0.06);
  --shadow-sm: 0 2rpx 10rpx rgba(20, 28, 40, 0.04);
  --radius: 24rpx;
  --radius-sm: 16rpx;
  --grad: linear-gradient(135deg, #0bd072 0%, #06a856 100%);

  background: var(--bg);
  color: var(--text-1);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 24rpx 28rpx 160rpx;
  box-sizing: border-box;
}

/* ===== 卡片 ===== */
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--line);
}

.card-hover {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
  opacity: 0.96;
}

/* ===== 区块标题 ===== */
.sec-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 20rpx;
}

.sec-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: var(--grad);
  margin-right: 14rpx;
}

/* ===== 分类标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  color: var(--primary-deep);
  font-weight: 500;
}

/* ===== 主按钮 ===== */
.btn-primary {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--grad);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, 0.28);
  line-height: 88rpx;
  height: 88rpx;
  padding: 0;
  box-sizing: border-box;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #b9e6cb;
  color: #fff;
  box-shadow: none;
}

/* ===== 空状态 ===== */
.empty {
  text-align: center;
  color: var(--text-3);
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.empty-emoji {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-sub {
  color: var(--text-3);
  font-size: 26rpx;
  margin-top: 8rpx;
}
