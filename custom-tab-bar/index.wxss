.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #ececec;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

.tab-item-active {
  color: #07c160;
}

.tab-emoji {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
}
