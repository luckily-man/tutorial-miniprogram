.a-hero {
  background: var(--grad);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.25);
}

.a-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.a-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  margin-top: 14rpx;
}

.a-openid {
  margin-top: 12rpx;
  color: #fff;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 12rpx;
  padding: 12rpx 18rpx;
  word-break: break-all;
}

.a-input {
  width: 100%;
  box-sizing: border-box;
  background: #f6f8fa;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
  color: var(--text-1);
  margin-bottom: 20rpx;
}

.user-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.user-row:last-child {
  border-bottom: none;
}

.user-openid {
  font-size: 26rpx;
  color: var(--text-1);
  word-break: break-all;
}

.user-role {
  font-size: 22rpx;
  color: var(--text-3);
  margin-top: 8rpx;
}

.role-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.role-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-2);
  background: #f6f8fa;
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 14rpx 0;
}

.role-btn.on {
  color: #fff;
  background: var(--grad);
  border-color: transparent;
}

.a-empty {
  color: var(--text-3);
  font-size: 26rpx;
  text-align: center;
  padding: 30rpx 0;
}

.a-tip-inline {
  font-size: 22rpx;
  color: var(--text-3);
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.invite-box {
  display: flex;
  align-items: center;
  background: #eafaf0;
  border: 1rpx solid #b7ebc8;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  margin-top: 18rpx;
}

.invite-code {
  flex: 1;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: #07c160;
}

.invite-copy {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #fff;
  background: #07c160;
  border-radius: 999rpx;
  padding: 10rpx 28rpx;
}

.invite-hint {
  font-size: 22rpx;
  color: var(--text-3);
  line-height: 1.6;
  margin-top: 12rpx;
}

.preview-card {
  border: 1rpx solid #b7ebc8;
  background: #f6fcf9;
}

.preview-exit {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: #06a856;
  background: #eafaf0;
  border-radius: 999rpx;
  padding: 14rpx 0;
}

.a-tip {
  font-size: 22rpx;
  color: var(--text-3);
  text-align: center;
  margin-top: 24rpx;
  line-height: 1.7;
}

.denied {
  margin-top: 200rpx;
  text-align: center;
  padding: 0 60rpx;
  color: var(--text-2);
}

.denied-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.denied-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-1);
}

.denied-sub {
  font-size: 26rpx;
  color: var(--text-3);
  margin-top: 16rpx;
  line-height: 1.7;
}
