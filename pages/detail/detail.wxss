.detail {
  padding-top: 24rpx;
}

/* 头部 hero */
.hero {
  display: flex;
  align-items: center;
  background: var(--grad);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.25);
}

.h-emoji {
  width: 104rpx;
  height: 104rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-right: 24rpx;
}

.h-info {
  flex: 1;
  min-width: 0;
}

.h-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.h-meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.h-meta .tag {
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
}

.h-author {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  margin-left: 16rpx;
}

.summary {
  font-size: 28rpx;
  color: var(--text-2);
  line-height: 1.7;
}

/* 区块标题 */
.sec-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 24rpx;
}

.sec-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 6rpx;
  background: var(--grad);
  margin-right: 16rpx;
}

.video {
  width: 100%;
  height: 420rpx;
  border-radius: 18rpx;
  background: #000;
}

.no-video {
  text-align: center;
  color: var(--text-3);
  padding: 48rpx 0;
}

.nv-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.detail-del {
  margin: 16rpx 4rpx 0;
  text-align: center;
  color: #e54d42;
  font-size: 28rpx;
  padding: 24rpx;
  background: #fff0ef;
  border-radius: 16rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.step:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.step-no {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: var(--grad);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
  box-shadow: 0 6rpx 14rpx rgba(7, 193, 96, 0.3);
}

.step-body {
  flex: 1;
  min-width: 0;
}

.step-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 10rpx;
}

.step-text {
  font-size: 27rpx;
  color: var(--text-2);
  line-height: 1.7;
}

.empty-emoji {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}
