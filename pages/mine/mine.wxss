/* 头部 hero */
.hero {
  display: flex;
  align-items: center;
  background: var(--grad);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.25);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
}

.mine-name {
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.mine-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.item {
  display: flex;
  align-items: center;
}

.item-emoji {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eafff3 0%, #d6f7e6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 12rpx;
}

.item-meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
}

.dot {
  margin: 0 12rpx;
  color: var(--text-3);
}

.m {
  color: var(--text-3);
}

.item-del {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 12rpx 26rpx;
  font-size: 26rpx;
  color: #e54d42;
  background: #fff0ef;
  border-radius: 999rpx;
}

.item-del:active {
  background: #ffe0de;
}

.upload-btn {
  margin-top: 28rpx;
}

/* 邀请码激活输入框 */
.a-input {
  width: 100%;
  box-sizing: border-box;
  background: #f6f8fa;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
  font-size: 30rpx;
  color: var(--text-1);
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.a-tip-inline {
  font-size: 22rpx;
  color: var(--text-3);
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.denied {
  margin-top: 200rpx;
  text-align: center;
  padding: 0 60rpx;
  color: var(--text-2);
}

.denied-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.denied-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-1);
}

.denied-sub {
  font-size: 26rpx;
  color: var(--text-3);
  margin-top: 16rpx;
  line-height: 1.7;
}

.empty-emoji {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-sub {
  color: var(--text-3);
  font-size: 26rpx;
  margin-top: 8rpx;
}
