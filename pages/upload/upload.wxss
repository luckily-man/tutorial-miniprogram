.page-head {
  margin: 8rpx 4rpx 24rpx;
}

.ph-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-1);
}

.ph-sub {
  font-size: 26rpx;
  color: var(--text-3);
  margin-top: 10rpx;
}

/* 区块标题 */
.sec-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 24rpx;
}

.sec-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 6rpx;
  background: var(--grad);
  margin-right: 16rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-last {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: var(--text-2);
  margin-bottom: 14rpx;
  font-weight: 500;
}

.req {
  color: #e54d42;
}

.input,
.textarea,
.picker,
.step-input {
  width: 100%;
  box-sizing: border-box;
  background: #f6f8fa;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  padding: 22rpx;
  font-size: 28rpx;
  color: var(--text-1);
  transition: border-color 0.2s, box-shadow 0.2s;
}

/* 单行输入框：显式高度 + 行高，避免 placeholder 竖向被裁切显示一半 */
.input {
  padding: 0 22rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.ph {
  color: var(--text-3);
}

.input:focus,
.textarea:focus,
.step-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.12);
  background: #fff;
}

.textarea,
.step-input {
  height: 150rpx;
  line-height: 1.5;
}

.picker {
  color: var(--text-1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-caret {
  color: var(--text-3);
}

.step-item {
  position: relative;
  background: #f6f8fa;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.step-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary-deep);
  background: var(--primary-soft);
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  margin-bottom: 14rpx;
}

.step-input {
  background: #fff;
  height: 130rpx;
}

.step-del {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  color: #999;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-step {
  text-align: center;
  color: var(--primary-deep);
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx;
  border: 1rpx dashed var(--primary);
  border-radius: 16rpx;
  background: var(--primary-tint);
}

.video-pick {
  border: 1rpx dashed #cfd6dd;
  border-radius: 18rpx;
  padding: 56rpx 0;
  text-align: center;
  color: var(--text-3);
  background: #fafbfc;
}

.pick-plus {
  font-size: 60rpx;
  line-height: 1;
  color: var(--primary);
}

.pick-text {
  font-size: 26rpx;
  margin-top: 14rpx;
  color: var(--text-2);
}

.video-box {
  position: relative;
}

.video {
  width: 100%;
  height: 380rpx;
  border-radius: 18rpx;
  background: #000;
}

.video-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
}

.video-replace,
.video-del {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
}

.video-replace {
  color: var(--primary-deep);
  background: var(--primary-tint);
  border: 1rpx solid var(--primary-soft);
}

.video-del {
  color: #e54d42;
  background: #fff5f4;
  border: 1rpx solid #f7d6d2;
}

.submit {
  margin-top: 8rpx;
}

.tip {
  font-size: 22rpx;
  color: var(--text-3);
  text-align: center;
  margin-top: 24rpx;
  line-height: 1.7;
}

.denied {
  margin-top: 200rpx;
  text-align: center;
  padding: 0 60rpx;
  color: var(--text-2);
}

.denied-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.denied-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-1);
}

.denied-sub {
  font-size: 26rpx;
  color: var(--text-3);
  margin-top: 16rpx;
  line-height: 1.7;
}
